APP_NAME=NL2SQL Agent API
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8787
FRONTEND_ORIGIN=http://localhost:4242
DATABASE_URL=mysql+asyncmy://sqlagent_ro:<password>@127.0.0.1:3306?charset=utf8mb4
DATABASE_NAMES=your_database
SCHEMA_INCLUDE_TABLES=your_database.your_table_a,your_database.your_table_b
REDIS_URL=redis://localhost:6379/0
QUERY_RESULT_LIMIT=200
DATABASE_READONLY_REQUIRED=true
SCHEMA_SYNC_TIMEOUT_SECONDS=600
AGENT_REQUEST_TIMEOUT_SECONDS=600
AGENT_LLM_NODE_TIMEOUT_SECONDS=600
SQL_EXPLAIN_TIMEOUT_SECONDS=600
QUERY_EXECUTION_TIMEOUT_SECONDS=600
LLM_PROVIDER=mock
LLM_MODEL=mimo-v2.5-pro
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
BUSINESS_SEMANTIC_YAML_ENABLED=false
SCHEMA_WATCHER_ENABLED=true
SCHEMA_WATCHER_INTERVAL_SECONDS=30

